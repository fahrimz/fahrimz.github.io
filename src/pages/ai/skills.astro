---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";

const rows = [
  {
    command: "npx skills add expo/skills",
    display: "expo/skills",
    skills: "add-app-clip, building-native-ui, eas-update-insights, expo-api-routes, expo-brownfield, expo-cicd-workflows, expo-deployment, expo-dev-client, expo-module, expo-tailwind-setup, expo-ui-jetpack-compose, expo-ui-swift-ui, native-data-fetching, upgrading-expo, use-dom",
    note: "/upgrading-expo make life easier. Truly.",
  },
  {
    command: "npx skills add mattpocock/skills",
    display: "mattpocock/skills",
    skills: "caveman, diagnose, grill-me, grill-with-docs, handoff, improve-codebase-architecture, setup-matt-pocock-skills, tdd, to-issues, to-prd, triage, write-a-skill",
    note: "/grill-me is what I go to for serious things (or if I don't understand what I'm doing)",
  },
  {
    command: "npx skills add vercel-labs/agent-skills",
    display: "vercel-labs/agent-skills",
    skills: "deploy-to-vercel, vercel-cli-with-tokens, vercel-composition-patterns, vercel-deploy, vercel-optimize, vercel-react-best-practices, vercel-react-native-skills, vercel-react-view-transitions, web-design-guidelines",
    note: "I like to play around with /frontend-design, no standing applause at the moment though.",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Skills — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body class="h-full flex flex-col gap-4 max-w-3xl mx-auto mb-20">
    <Header />
    <main class="main">
      <h1>Skills</h1>
      <p>List of skills I use daily. Putting it here so I can just install them again if I change harness, etc.</p>

      <div class="overflow-x-auto">
        <table class="w-full border-collapse not-prose">
          <thead>
            <tr class="border-b border-gray-300">
              <th class="text-left py-2 pr-4 font-bold">Skill Group</th>
              <th class="text-left py-2 font-bold">Note</th>
            </tr>
          </thead>
          <tbody>
            {
              rows.map((row) => (
                <tr class="border-b border-gray-200">
                  <td class="py-3 pr-4 align-top">
                    <div class="flex items-center gap-2">
                      <button
                        class="copy-btn shrink-0 text-gray-400 hover:text-gray-700 transition-colors cursor-pointer"
                        data-copy={row.command}
                        aria-label="Copy command"
                      >
                        <svg class="copy-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                        </svg>
                        <svg class="check-icon hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="20 6 9 17 4 12"/>
                        </svg>
                      </button>
                      <code class="bg-gray-100 px-2 py-1 rounded text-sm whitespace-nowrap">
                        {row.display}
                      </code>
                    </div>
                  </td>
                  <td class="py-3 align-top text-gray-600 text-sm">
                    {row.note}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </main>
  </body>
</html>

<script>
  document.querySelectorAll(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.getAttribute("data-copy");
      await navigator.clipboard.writeText(text);

      const icon = btn.querySelector(".copy-icon");
      const check = btn.querySelector(".check-icon");
      icon.classList.add("hidden");
      check.classList.remove("hidden");

      setTimeout(() => {
        icon.classList.remove("hidden");
        check.classList.add("hidden");
      }, 2000);
    });
  });
</script>
